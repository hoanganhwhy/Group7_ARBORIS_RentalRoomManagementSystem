# Frontend
# Dùng đường dẫn tương đối "/api" thay vì "http://localhost:5000/api".
# Vite dev server đã có sẵn cấu hình proxy "/api" -> "http://localhost:5000"
VITE_API_URL=/api

# Server
PORT=5000
JWT_SECRET=thay-doi-chuoi-bi-mat-nay-thanh-cua-ban

# Google login / Gemini chatbot (optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Thông tin Ngân hàng (Ví dụ)
BANK_ID=970422
BANK_ACCOUNT_NO=0123456789
BANK_ACCOUNT_NAME="TEN CHU TAI KHOAN"
VIETQR_TEMPLATE=compact2

# Tiền tố mã thanh toán của HostelMate (Dùng cho VietQR & SePay)
PAYMENT_PREFIX=HM

# Khóa webhook SePay (Dùng để xác thực request từ SePay)
SEPAY_WEBHOOK_API_KEY=your_sepay_api_key_here

# Chỉ chấp nhận webhook thuộc đúng tài khoản này
SEPAY_ALLOWED_ACCOUNT_NUMBERS=0123456789

LANDLORD_NAME=Chủ trọ ARBORIS
LANDLORD_PHONE=
RESET_DB_ON_START=false
